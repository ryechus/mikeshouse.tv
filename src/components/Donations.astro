---
import TwitchGlitch from "@images/glitch_flat_white.png";
import { backendUrl, siteUrl } from "@config";
const prepopValues = [
  {
    text: "2",
    amount: 200,
  },
  {
    text: "5",
    amount: 500,
  },
  {
    text: "15",
    amount: 1500,
  },
];

const buttonClasses =
  "m-1 sm:m-2 bg-black text-white p-4 py-3 rounded-md hover:bg-gray-100 hover:text-black border-3 cursor-pointer text-lg w-30 uppercase";
const buttonSelector = "preprop-vals";
const twitchClientId = "689cezddnt6abeht2rj9qqkj89ptol";
const implicitGrant = `https://id.twitch.tv/oauth2/authorize?client_id=${twitchClientId}&redirect_uri=${siteUrl}/tips&response_type=token&scope=user%3Aread%3Aemail`;
---

<form action=`${backendUrl}/payment-link/create` method="post">
  <input id="userEmail" name="userEmail" type="hidden" />
  <div class="w-7/8 sm:w-full mx-auto">
    <div class="font-roboto-flex">
      <p>
        Support the stream!<br />
      </p>
    </div>
    <div class="flex flex-row flex-wrap justify-center w-full">
      {
        prepopValues.map((val) => (
          <button
            data-amount={val.amount}
            class={`${buttonClasses} ${buttonSelector}`}
          >
            ${val.text}
          </button>
        ))
      }
    </div>
    <div
      class="flex items-center rounded-md bg-white outline-1 -outline-offset-1 outline-black outline-3 has-[input:focus-within]:outline-2 has-[input:focus-within]:-outline-offset-2 has-[input:focus-within]:outline-indigo-600 w-30 sm:w-30 mx-2 sm:mx-auto text-lg my-2 pl-3 mx-auto"
    >
      <div class="text-gray-500 select-none">$</div>
      <input
        id="userAmount"
        data-price-type="VARIABLE_PRICING"
        type="number"
        name="tipAmount"
        placeholder="0.00"
        class="w-full p-4 py-3 pl-1 placeholder:text-gray-400 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none uppercase text-center"
      />
    </div>
    <div id="userNameDiv" class="my-5 hidden">
      <div
        class="flex items-center rounded-md bg-white outline-1 -outline-offset-1 outline-black outline-3 has-[input:focus-within]:outline-2 has-[input:focus-within]:-outline-offset-2 has-[input:focus-within]:outline-indigo-600 w-3/4 mx-2 sm:mx-auto text-lg my-2 pl-3 mx-auto font-roboto-flex"
      >
        <div class="text-gray-500 select-none">name:</div>
        <input
          readonly
          id="userName"
          type="text"
          name="userName"
          placeholder="handle"
          class="w-full p-4 py-3 pl-1 placeholder:text-gray-400 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none text-left"
        />
      </div>
      <div
        class="flex items-center rounded-md bg-white outline-1 -outline-offset-1 outline-black outline-3 has-[input:focus-within]:outline-2 has-[input:focus-within]:-outline-offset-2 has-[input:focus-within]:outline-indigo-600 w-3/4 mx-2 sm:mx-auto text-lg my-2 pl-3 mx-auto font-roboto-flex mt-5"
      >
        <div class="text-gray-500 select-none">message:</div>
        <input
          id="tipMessage"
          type="text"
          name="tipMessage"
          placeholder=""
          class="w-full p-4 py-3 pl-1 placeholder:text-gray-400 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none text-left"
        />
      </div>
    </div>
    <a class="mr-3 no-underline connectWithTwitch" href={implicitGrant}>
      <div
        id="connectWithTwitch"
        class="bg-[#9146ff] w-50 mx-auto p-4 my-4 hidden"
      >
        <p
          class="flex justify-center text-white font-roboto-flex text-xs uppercase items-center"
        >
          Connect with Twitch<img
            class="twitchIcon w-5 ml-2"
            src={TwitchGlitch.src}
          />
        </p>
      </div>
    </a>
    <div class="w-full">
      <button
        id="checkoutBtn"
        class="uppercase text-xl cursor-pointer bg-black text-white p-4 py-3 rounded-md disabled:bg-gray-100 hover:text-gray-500 active:text-gray-500 hover:bg:gray-700 active:bg-gray-700"
        disabled
      >
        submit
      </button>

      <p class="text-xs font-roboto-flex pt-5">
        All donations are non-refundable.
      </p>
    </div>
  </div>
</form>

<style>
  a.connectWithTwitch:active {
    text-color: white;
  }
  a.connectWithTwitch:hover {
    text-color: white;
  }
  a.connectWithTwitch {
    text-color: white;
  }
</style>

<script define:vars={{ buttonSelector, twitchClientId }}>
  const buttons = document.querySelectorAll(`.${buttonSelector}`);
  let amount = 500;
  let userEmail = "";
  let userDisplayName = "";
  let userTipMessage = "";

  function setAmount(amount) {
    const userInput = document.getElementById("userAmount");
    userInput.value = (amount / 100).toFixed(2);
  }

  function handleEvent(e) {
    amount = e.target.dataset.amount;
    setAmount(amount);
    e.preventDefault();
  }

  buttons.forEach((button) => {
    button.addEventListener("touchstart", handleEvent);
    button.addEventListener("click", handleEvent);
  });

  function getCookie(name) {
    const nameEQ = name + "=";
    const cookies = document.cookie.split(";");

    for (let i = 0; i < cookies.length; i++) {
      let cookie = cookies[i].trim();
      if (cookie.indexOf(nameEQ) === 0) {
        return cookie.substring(nameEQ.length);
      }
    }
    return null;
  }

  async function getTwitchUser(access_token) {
    const bearerToken = {
      Authorization: `Bearer ${access_token}`,
    };
    const ClientId = {
      "Client-Id": twitchClientId,
    };
    const validatedUser = await fetch("https://id.twitch.tv/oauth2/validate", {
      headers: bearerToken,
    });
    const response = await validatedUser.json();
    const userId = response.user_id;

    const params = new URLSearchParams();
    params.append("id", userId);

    const userData = await fetch(
      `https://api.twitch.tv/helix/users/?${params}`,
      {
        headers: { ...bearerToken, ...ClientId },
      },
    );
    const userDataResponse = await userData.json();
    const data = userDataResponse.data[0];

    userEmail = data.email;
    userDisplayName = data.display_name;

    const usernameDiv = document.getElementById("userNameDiv");
    usernameDiv.classList.remove("hidden");

    const usernameElement = document.getElementById("userName");
    usernameElement.value = userDisplayName;

    const emailElement = document.getElementById("userEmail");
    emailElement.value = userEmail;

    const checkoutBtnElement = document.getElementById("checkoutBtn");
    checkoutBtnElement.disabled = false;
  }

  function parseAccessTokenFromHash() {
    const hash = document.location.hash.substring(1); // Remove '#'
    if (hash) {
      const params = new URLSearchParams(hash);
      const accessToken = params.get("access_token");
      const today = new Date();
      const sixtyDaysFromNow = new Date(
        today.getTime() + 60 * 24 * 60 * 60 * 1000,
      );

      document.cookie = `twitchAccessToken=${accessToken}; expires=${sixtyDaysFromNow.toUTCString()}`;
    }
  }

  parseAccessTokenFromHash();

  const cookieToken = getCookie("twitchAccessToken");
  if (cookieToken) {
    getTwitchUser(cookieToken);
  } else {
    const element = document.getElementById("connectWithTwitch");
    element.classList.remove("hidden");
  }

  const checkoutBtnElement = document.getElementById("checkoutBtn");

  setAmount(amount);
</script>
