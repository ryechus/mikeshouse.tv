---
import data from "@data/yt-playlist.json";

const items = data.items;
const nonPrivate = items.filter(
  (item: any) => item.snippet.title.toLowerCase() !== "private video",
);

const youtubeUrl = (videoId: string) => {
  return `https://youtu.be/${videoId}`;
};
---

<div
  class="font-roboto-flex font-semibold px-4.25 sm:px-10 flex flex-row flex-wrap"
>
  {
    nonPrivate.map((item: any) => (
      <div class="space-around mx-auto sm:px-10 sm:max-w-7/8 lg:p-1.5 lg:basis-1/3 lg:max-w-3/4 mb-5 sm:mb-0">
        <a
          class="no-underline lowercase"
          href={youtubeUrl(item.contentDetails.videoId)}
        >
          <img
            class="thumbnail rounded-xs"
            src={item.snippet.thumbnails.maxres.url}
          />
          <p class="text-left mt-2">{item.snippet.title}</p>
        </a>
      </div>
    ))
  }
</div>

<style>
  img.thumbnail:hover {
    filter: brightness(85%); /* 100% is normal, lower is darker */
  }
</style>
