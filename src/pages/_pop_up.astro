---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Socials from "../components/Socials.astro";

const textUrl = `/${encodeURIComponent("POP UP may 24 2025 txt.png")}`;
const backgroundUrl = `/${encodeURIComponent("POP UP may 24 2025 bg.png")}`;
const ogImageUrl = `/${encodeURIComponent("POP UP may 24 2025 banner.png")}`;
const ticketUrl = "https://posh.vip/f/2bb41?t=mikeshouse-tv";
const eventDate = "May 12, 2025 00:00:00"
const eventDateTime = new Date(eventDate)
---

<Layout title=`Mike's House presents..Pop Up - ${eventDateTime} @ Native Son LA` backgroundUrl={backgroundUrl} ogImageUrl={ogImageUrl}>
	<main>
		<img
			class="poster-text"
			src={textUrl}
			alt="transparent poster with text only for Offline event"
		/>
		<Footer ticketUrl={ticketUrl}/>
		<Socials />
		<div class="poster-text">
			<h1>Mike's House presents Pop Up</h1>
			<h2>Lineup</h2>
			<ul>
        <li>Fake Laflare</li>
        <li>Fragile Fruit</li>
        <li>Ketchup</li>
				<li>Mikezilla</li>
        <li>Purple Violet</li>
        <li>SMLS</li>
        <li>WRMBRW</li>        
			</ul>
		</div>
	</main>
</Layout>

<style>
  main {
    color: #ffffef;
    font-size: 20px;
  }
  div.poster-text {
    visibility: hidden;
  }
  .poster-text {
    max-height: 96vh;
    margin: 0 auto;
    display: block;
    margin-top: 0px;
    margin-bottom: -80px;
  }
  @media (max-width: 590px) {
    .poster-text {
      max-width: 435px;
      width: 100%;
      max-height: 96vh;
      display: block;
      margin-bottom: -75px;
    }
  }
  .astro-a {
    position: absolute;
    top: -32px;
    left: 50%;
    transform: translatex(-50%);
    width: 220px;
    height: auto;
    z-index: -1;
  }
  h1 {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    text-align: center;
    margin-bottom: 1em;
  }
  .text-gradient {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
  .instructions {
    margin-bottom: 2rem;
    border: 1px solid rgba(var(--accent-light), 25%);
    background: linear-gradient(
      rgba(var(--accent-dark), 66%),
      rgba(var(--accent-dark), 33%)
    );
    padding: 1.5rem;
    border-radius: 8px;
  }
  .instructions code {
    font-size: 0.8em;
    font-weight: bold;
    background: rgba(var(--accent-light), 12%);
    color: rgb(var(--accent-light));
    border-radius: 4px;
    padding: 0.3em 0.4em;
  }
  .instructions strong {
    color: rgb(var(--accent-light));
  }
  .link-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
    gap: 2rem;
    padding: 0;
  }
</style>
<style is:global>
  .page-container {
    background-size: 100vw 100vw !important;
    background-position: center !important;

    animation-duration: 25s !important;
    /* animation-name: bg-rotate !important; */
    animation-iteration-count: infinite !important;
    /* animation-timing-function: cubic-bezier() !important; */
  }

  @media (max-width: 590px) {
    .page-container {

      background-size: 1024px 1024px !important;
      /* background-position: 500px -200px; */
    }
  }



  @keyframes bg-rotate {
    from {
      transform: rotate(0deg);
    }

    50% {
      transform: rotate(180deg);
    }

    to {
      transform: rotate(360deg);
    }
  }
</style>
